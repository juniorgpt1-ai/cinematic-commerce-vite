# Copy to .env.production (or set in your hosting provider's env config) before deploying.
# Digits only, with country code — e.g. 5531999998888 for a BH number.
VITE_WHATSAPP_NUMBER=

# Production domain (used for canonical URL, OG tags, sitemap, structured data).
# Set to your actual domain before deploying to production.
VITE_SITE_URL=https://SEU-DOMINIO.com
